# Dependencies — reinstalled inside the container
node_modules

# Compiled output — rebuilt inside the container
dist

# Version control
.git
.gitignore

# Environment files and secrets — never copy into the build context.
# Runtime config is injected via envsubst at container start, not baked in.
.env
.env.*
!.env.example
*.pem
*.key

# Editor and OS artefacts
.DS_Store
*.local
.idea
.vscode

# Test output
coverage

# Docker files themselves (not needed in the build context)
Dockerfile
docker-compose.yml
.dockerignore

# Docs
*.md
